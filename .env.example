# Scope environment — copy to .env.local and fill in.

# ---------------------------------------------------------------------------
# Python compute service URL (Fly.io / Railway / Render endpoint)
# Leave unset locally and the Next.js /api/compute route falls back to the
# pre-built library reports (stub mode). Set in production to enable
# on-demand computation against scope_compute.py.
# ---------------------------------------------------------------------------
COMPUTE_API_URL=http://localhost:8000

# Default tenant ID (Phase 1 = grounded only). Public so client can read it.
NEXT_PUBLIC_TENANT_ID=grounded

# Legacy alias — older code still reads SCOPE_COMPUTE_URL. Keep both in sync
# until the migration to COMPUTE_API_URL is complete across all routes.
SCOPE_COMPUTE_URL=http://localhost:8000

# Default tenant for compute requests when none provided.
SCOPE_DEFAULT_TENANT=grounded

# ---------------------------------------------------------------------------
# Future: Supabase credentials (Phase 1 Day 4)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
